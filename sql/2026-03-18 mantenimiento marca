-- pedidosjb_pedidos.view_marca_set_talla source

CREATE OR REPLACE
ALGORITHM = UNDEFINED VIEW `pedidosjb_pedidos`.`view_marca_set_talla` AS
select
    `m`.`idmarca` AS `idmarca`,
    `m`.`nombre` AS `nombre`,
    `m`.`estado` AS `estado`,
    `m`.`idset_talla_preferido` AS `idset_talla_preferido`,
    `st`.`idset_talla` AS `idset_talla`,
    `st`.`grupo` AS `grupo`
from
    (`pedidosjb_pedidos`.`marca` `m`
join `pedidosjb_pedidos`.`set_talla` `st` on
    ((`m`.`idset_talla_preferido` = `st`.`idset_talla`)))
order by
    `m`.`idmarca` desc;


